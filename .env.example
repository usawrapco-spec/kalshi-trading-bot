# Kalshi API Credentials
KALSHI_API_KEY_ID=your-key-id-here
KALSHI_PRIVATE_KEY=your-private-key-here
KALSHI_API_HOST=https://demo-api.kalshi.co

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# xAI Grok API (for GrokNewsAnalysis strategy)
XAI_API_KEY=your-xai-api-key-here

# Paper Trading (default: $10 paper balance, no real trading)
PAPER_BALANCE=10.0
ENABLE_TRADING=false

# Strategy Toggles
ENABLE_WEATHER=true
ENABLE_GROK=true
ENABLE_PROB_ARB=true
ENABLE_SPORTS_NO=true
ENABLE_NEAR_CERTAINTY=true

# Risk Management
MAX_POSITION_SIZE=100
MAX_DAILY_LOSS=500
MAX_ORDER_SIZE=50

# Monitoring
CHECK_INTERVAL_SECONDS=30
LOG_LEVEL=INFO

# Railway sets this automatically
# PORT=5000
