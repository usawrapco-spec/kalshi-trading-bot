# Kalshi API Credentials
KALSHI_API_KEY_ID=your-key-id-here
# PEM RSA private key — paste the full key, or on Railway use \n for newlines:
# e.g. -----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBA...\n-----END RSA PRIVATE KEY-----
KALSHI_PRIVATE_KEY=your-private-key-here

# API Host (use demo for testing!)
# Demo: https://demo-api.kalshi.co
# Live: https://api.elections.kalshi.com
KALSHI_API_HOST=https://demo-api.kalshi.co

# Supabase Configuration (separate project from your main app!)
SUPABASE_URL=https://your-project.supabase.co
# Accepts either SUPABASE_KEY or SUPABASE_SERVICE_KEY
SUPABASE_KEY=your-service-role-key-here

# Risk Management
MAX_POSITION_SIZE=100
MAX_DAILY_LOSS=500
MAX_ORDER_SIZE=50

# Strategy Settings
ENABLE_ARBITRAGE=true
ENABLE_MOMENTUM=true
ENABLE_EVENT_BASED=false

# Monitoring
CHECK_INTERVAL_SECONDS=30
LOG_LEVEL=INFO
