# =============================================================================
# Kalshi Trading Bot - Environment Variables
# =============================================================================
# Copy this file and fill in real values:
#   cp env.example .env
#
# On the server, these are set in the systemd service file. Edit with:
#   sudo systemctl edit kalshi-bot
# =============================================================================

# --- Database ---
# Auto-generated by setup.sh. PostgreSQL connection string.
DATABASE_URL=postgresql://kalshi:YOUR_PASSWORD@localhost:5432/kalshi

# --- Kalshi API ---
# Your Kalshi API key ID (from https://kalshi.com/account/api)
KALSHI_API_KEY_ID=your_api_key_id_here

# Your Kalshi private key (RSA private key, PEM format)
# Can be the key contents or a file path.
KALSHI_PRIVATE_KEY=your_private_key_here

# --- Trading ---
# Set to "true" to enable live trading. Default is "false" (paper/dry-run mode).
ENABLE_TRADING=false

# --- Server ---
# Port the Flask app listens on. nginx proxies port 80 -> this port.
PORT=8080

# --- Optional: Supabase (if using Supabase instead of local PostgreSQL) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_anon_key
